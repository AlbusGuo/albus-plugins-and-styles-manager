{
	"name": "albus-psm",
	"version": "0.5.0",
	"description": "Manage community plugins and CSS snippets in one place.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
