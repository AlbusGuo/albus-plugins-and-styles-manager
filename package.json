		"esbuild": "^0.27.0",
		"eslint": "^9.38.0",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"tslib": "2.4.0",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
